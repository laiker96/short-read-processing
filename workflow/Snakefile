"""Accession-resolved ATAC-seq and ChIP-seq processing workflow."""

import sys
from pathlib import Path
from urllib.parse import urlparse


REPO_ROOT = Path(workflow.basedir).parent.resolve()
sys.path.insert(0, str(REPO_ROOT / "src"))

from short_read_processing.consensus import condition_specs
from short_read_processing.workflow_config import (
    resolve_input_paths,
    validate_workflow_config,
    wildcard_regex,
)


if not config:
    raise ValueError("Pass a resolved YAML with --configfile")
validate_workflow_config(config)
resolve_input_paths(config, Path.cwd())

PROJECT = str(config["project"])
RUN_ID = str(config["run_id"])
ASSAY = str(config["assay"])
RESULT_ROOT = str(Path(config["output_dir"]) / PROJECT / RUN_ID)
WORK_ROOT = str(Path("work") / PROJECT / RUN_ID)
SAMPLES = {str(sample["id"]): sample for sample in config["samples"]}
SAMPLE_IDS = list(SAMPLES)
TREATMENTS = [sample for sample in SAMPLE_IDS if SAMPLES[sample]["role"] == "treatment"]
CHIP_TREATMENTS = TREATMENTS if ASSAY.startswith("chip") else []
CHIP_CONTROLLED_TREATMENTS = [
    sample for sample in CHIP_TREATMENTS if SAMPLES[sample].get("control")
]
ATAC_SAMPLES = TREATMENTS if ASSAY == "atac" else []
ATAC_QPOIS_SAMPLES = [
    sample
    for sample in ATAC_SAMPLES
    if SAMPLES[sample]["peak_caller"]["command"] == "callpeak"
]
ATAC_QPOIS_PE_SAMPLES = [
    sample for sample in ATAC_QPOIS_SAMPLES if SAMPLES[sample]["layout"] == "paired"
]
HMMRATAC_SAMPLES = [
    sample
    for sample in ATAC_SAMPLES
    if SAMPLES[sample]["peak_caller"]["command"] == "hmmratac"
]

ATAC_QPOIS = config.get(
    "atac_qpois",
    {
        "fragment_maximum": 150,
        "minimum_exponent": 2,
        "maximum_exponent": 325,
        "merge_gap": 1,
        "minimum_length": 50,
        "maximum_length": 400,
    },
)
ATAC_CONSENSUS = config.get("atac_consensus", {"enabled": False})
ATAC_CONSENSUS_ENABLED = bool(ATAC_CONSENSUS.get("enabled"))
ATAC_CONDITION_SPECS = (
    condition_specs(
        ATAC_CONSENSUS["conditions"],
        sample_ids=ATAC_SAMPLES,
        minimum_replicates=int(ATAC_CONSENSUS["minimum_replicates"]),
    )
    if ATAC_CONSENSUS_ENABLED
    else []
)
ATAC_CONDITIONS = {spec.condition_id: spec for spec in ATAC_CONDITION_SPECS}
ATAC_CONDITION_METHOD = {}
for condition, specification in ATAC_CONDITIONS.items():
    methods = {
        SAMPLES[sample]["peak_caller"]["command"] for sample in specification.samples
    }
    layouts = {SAMPLES[sample]["layout"] for sample in specification.samples}
    if len(methods) != 1 or len(layouts) != 1:
        raise ValueError(f"ATAC condition {condition} mixes peak callers or layouts")
    method = methods.pop()
    if method == "callpeak":
        parameters = {
            (
                SAMPLES[sample]["peak_caller"]["qvalue"],
                SAMPLES[sample]["peak_caller"]["shift"],
                SAMPLES[sample]["peak_caller"]["extsize"],
            )
            for sample in specification.samples
        }
        if len(parameters) != 1:
            raise ValueError(f"ATAC condition {condition} mixes MACS3 parameters")
        ATAC_CONDITION_METHOD[condition] = "qpois"
    else:
        parameters = {
            (
                SAMPLES[sample]["peak_caller"]["lower"],
                SAMPLES[sample]["peak_caller"]["upper"],
                SAMPLES[sample]["peak_caller"]["prescan_cutoff"],
            )
            for sample in specification.samples
        }
        if len(parameters) != 1:
            raise ValueError(f"ATAC condition {condition} mixes HMMRATAC parameters")
        ATAC_CONDITION_METHOD[condition] = "hmmratac"
ATAC_CONDITION_IDS = list(ATAC_CONDITIONS)
ATAC_QPOIS_CONDITIONS = [
    condition for condition in ATAC_CONDITION_IDS if ATAC_CONDITION_METHOD[condition] == "qpois"
]
ATAC_HMMRATAC_CONDITIONS = [
    condition
    for condition in ATAC_CONDITION_IDS
    if ATAC_CONDITION_METHOD[condition] == "hmmratac"
]

SAMPLE_RE = wildcard_regex(SAMPLE_IDS)
ATAC_RE = wildcard_regex(ATAC_SAMPLES)
ATAC_QPOIS_RE = wildcard_regex(ATAC_QPOIS_SAMPLES)
ATAC_QPOIS_PE_RE = wildcard_regex(ATAC_QPOIS_PE_SAMPLES)
HMMRATAC_RE = wildcard_regex(HMMRATAC_SAMPLES)
ATAC_CONDITION_RE = wildcard_regex(ATAC_CONDITION_IDS)
ATAC_QPOIS_CONDITION_RE = wildcard_regex(ATAC_QPOIS_CONDITIONS)
ATAC_HMMRATAC_CONDITION_RE = wildcard_regex(ATAC_HMMRATAC_CONDITIONS)
CHIP_TREATMENT_RE = wildcard_regex(CHIP_TREATMENTS)
CHIP_CONTROLLED_TREATMENT_RE = wildcard_regex(CHIP_CONTROLLED_TREATMENTS)

LANES = {}
RAW_FASTQ_BY_UNIT = {}
TRIMMED_FASTQ_BY_UNIT = {}
for sample_id, sample in SAMPLES.items():
    for index, r1 in enumerate(sample["r1"], start=1):
        lane = f"L{index:03d}"
        key = (sample_id, lane)
        LANES[key] = {"r1": r1, "r2": None}
        RAW_FASTQ_BY_UNIT[f"{sample_id}.{lane}.R1"] = r1
        if sample["layout"] == "paired":
            r2 = sample["r2"][index - 1]
            LANES[key]["r2"] = r2
            RAW_FASTQ_BY_UNIT[f"{sample_id}.{lane}.R2"] = r2

PE_LANES = [key for key in LANES if SAMPLES[key[0]]["layout"] == "paired"]
SE_LANES = [key for key in LANES if SAMPLES[key[0]]["layout"] == "single"]
PE_SAMPLE_RE = wildcard_regex(sorted({sample for sample, _lane in PE_LANES}))
SE_SAMPLE_RE = wildcard_regex(sorted({sample for sample, _lane in SE_LANES}))
LANE_RE = wildcard_regex(sorted({lane for _sample, lane in LANES}))

TRIMMED_R1 = {}
TRIMMED_R2 = {}
for sample_id, lane in LANES:
    suffix = "R1" if SAMPLES[sample_id]["layout"] == "paired" else "SE"
    r1_path = f"{WORK_ROOT}/trimmed/{sample_id}/{lane}_{suffix}.fastq.gz"
    TRIMMED_R1[(sample_id, lane)] = r1_path
    TRIMMED_FASTQ_BY_UNIT[f"{sample_id}.{lane}.R1"] = r1_path
    if SAMPLES[sample_id]["layout"] == "paired":
        r2_path = f"{WORK_ROOT}/trimmed/{sample_id}/{lane}_R2.fastq.gz"
        TRIMMED_R2[(sample_id, lane)] = r2_path
        TRIMMED_FASTQ_BY_UNIT[f"{sample_id}.{lane}.R2"] = r2_path

LANE_BAMS = {
    key: f"{WORK_ROOT}/alignment/lanes/{key[0]}.{key[1]}.coordsort.bam" for key in LANES
}

REFERENCE = config["reference"]
REFERENCE_PREPARATION = REFERENCE.get("preparation")
AUTO_PREPARE_REFERENCE = bool(
    REFERENCE_PREPARATION and REFERENCE_PREPARATION.get("mode") == "download"
)
REFERENCE_SOURCE_DIR = Path(REFERENCE["fasta"]).parent / "sources"
if AUTO_PREPARE_REFERENCE:
    REFERENCE_FASTA_ARCHIVE = str(
        REFERENCE_SOURCE_DIR
        / Path(urlparse(REFERENCE_PREPARATION["fasta"]["url"]).path).name
    )
    REFERENCE_ANNOTATION_ARCHIVE = str(
        REFERENCE_SOURCE_DIR
        / Path(urlparse(REFERENCE_PREPARATION["annotation"]["url"]).path).name
    )
    REFERENCE_BLACKLIST_ARCHIVE = str(
        REFERENCE_SOURCE_DIR
        / Path(urlparse(REFERENCE_PREPARATION["blacklist"]["url"]).path).name
    )
BT2_PREFIX = str(REFERENCE["bowtie2_index"])
BT2_SUFFIXES = [".1.bt2", ".2.bt2", ".3.bt2", ".4.bt2", ".rev.1.bt2", ".rev.2.bt2"]
BT2_INDEX = [BT2_PREFIX + suffix for suffix in BT2_SUFFIXES]
FASTA_INDEX = str(REFERENCE["fasta"]) + ".fai"

FINAL_BAMS = {sample: f"{RESULT_ROOT}/bam/{sample}.final.bam" for sample in SAMPLE_IDS}
FINAL_BAIS = {sample: FINAL_BAMS[sample] + ".bai" for sample in SAMPLE_IDS}
CHIP_BIGWIGS = {
    sample: f"{RESULT_ROOT}/tracks/{sample}.CPM.bw" for sample in CHIP_TREATMENTS
}
ATAC_SHIFTED_BIGWIGS = {
    sample: f"{RESULT_ROOT}/tracks/{sample}.Tn5-shifted.CPM.bw" for sample in ATAC_SAMPLES
}

ATAC_ROOT = f"{RESULT_ROOT}/atac"
ATAC_WORK = f"{WORK_ROOT}/atac"
ATAC_FRAGMENT_MAXIMUM = int(ATAC_QPOIS["fragment_maximum"])
ATAC_SHORT_BAMS = {
    sample: f"{ATAC_WORK}/replicates/{sample}.fragments-lt{ATAC_FRAGMENT_MAXIMUM}.bam"
    for sample in ATAC_QPOIS_PE_SAMPLES
}
ATAC_SHORT_BAIS = {sample: ATAC_SHORT_BAMS[sample] + ".bai" for sample in ATAC_QPOIS_PE_SAMPLES}
ATAC_INSERTIONS = {
    sample: f"{ATAC_WORK}/replicates/{sample}.tn5-insertions.bed.gz"
    for sample in ATAC_QPOIS_SAMPLES
}
ATAC_INSERTION_COUNTS = {
    sample: f"{ATAC_WORK}/replicates/{sample}.tn5-insertions.count.txt"
    for sample in ATAC_QPOIS_SAMPLES
}
ATAC_REPLICATE_CANDIDATES = {
    sample: f"{ATAC_WORK}/replicates/{sample}/peaks/{sample}.candidates.narrowPeak"
    for sample in ATAC_QPOIS_SAMPLES
}
ATAC_REPLICATE_PILEUP_BDG = {
    sample: f"{ATAC_WORK}/replicates/{sample}.pileup.bdg" for sample in ATAC_QPOIS_SAMPLES
}
ATAC_REPLICATE_LAMBDA_BDG = {
    sample: f"{ATAC_WORK}/replicates/{sample}.lambda.bdg" for sample in ATAC_QPOIS_SAMPLES
}
ATAC_REPLICATE_QPOIS_BDG = {
    sample: f"{ATAC_WORK}/replicates/{sample}.qpois.bdg" for sample in ATAC_QPOIS_SAMPLES
}
ATAC_REPLICATE_REFINED = {
    sample: f"{ATAC_WORK}/replicates/{sample}/peaks/{sample}.qpois-refined.bed"
    for sample in ATAC_QPOIS_SAMPLES
}
ATAC_REPLICATE_EXCLUDED = {
    sample: f"{ATAC_WORK}/replicates/{sample}/peaks/{sample}.qpois-excluded.bed"
    for sample in ATAC_QPOIS_SAMPLES
}
ATAC_REPLICATE_STATS = {
    sample: f"{ATAC_WORK}/replicates/{sample}/peaks/{sample}.qpois-refinement.json"
    for sample in ATAC_QPOIS_SAMPLES
}
ATAC_REPLICATE_HMM_PEAKS = {
    sample: f"{ATAC_WORK}/replicates/{sample}/peaks/{sample}.hmmratac.narrowPeak"
    for sample in HMMRATAC_SAMPLES
}

ATAC_CONDITION_INSERTIONS = {
    condition: f"{ATAC_WORK}/conditions/{condition}.tn5-insertions.bed.gz"
    for condition in ATAC_QPOIS_CONDITIONS
}
ATAC_CONDITION_INSERTION_COUNTS = {
    condition: f"{ATAC_WORK}/conditions/{condition}.tn5-insertions.count.txt"
    for condition in ATAC_QPOIS_CONDITIONS
}
ATAC_CONDITION_CANDIDATES = {
    condition: f"{ATAC_ROOT}/conditions/{condition}/peaks/{condition}.candidates.narrowPeak"
    for condition in ATAC_QPOIS_CONDITIONS
}
ATAC_CONDITION_PILEUP_BDG = {
    condition: f"{ATAC_WORK}/conditions/{condition}.pileup.bdg"
    for condition in ATAC_QPOIS_CONDITIONS
}
ATAC_CONDITION_LAMBDA_BDG = {
    condition: f"{ATAC_WORK}/conditions/{condition}.lambda.bdg"
    for condition in ATAC_QPOIS_CONDITIONS
}
ATAC_CONDITION_QPOIS_BDG = {
    condition: f"{ATAC_WORK}/conditions/{condition}.qpois.bdg"
    for condition in ATAC_QPOIS_CONDITIONS
}
ATAC_CONDITION_REFINED = {
    condition: f"{ATAC_ROOT}/conditions/{condition}/peaks/{condition}.qpois-refined.bed"
    for condition in ATAC_QPOIS_CONDITIONS
}
ATAC_CONDITION_EXCLUDED = {
    condition: f"{ATAC_ROOT}/conditions/{condition}/peaks/{condition}.qpois-excluded.bed"
    for condition in ATAC_QPOIS_CONDITIONS
}
ATAC_CONDITION_REFINEMENT_STATS = {
    condition: f"{ATAC_ROOT}/conditions/{condition}/peaks/{condition}.qpois-refinement.json"
    for condition in ATAC_QPOIS_CONDITIONS
}
ATAC_CONDITION_PILEUP_BW = {
    condition: f"{ATAC_ROOT}/conditions/{condition}/tracks/{condition}.MACS3-pileup.unscaled.bw"
    for condition in ATAC_QPOIS_CONDITIONS
}
ATAC_CONDITION_QPOIS_BW = {
    condition: f"{ATAC_ROOT}/conditions/{condition}/tracks/{condition}.qpois.bw"
    for condition in ATAC_QPOIS_CONDITIONS
}
ATAC_CONDITION_HMM_BAMS = {
    condition: f"{ATAC_WORK}/conditions/{condition}.pooled.bam"
    for condition in ATAC_HMMRATAC_CONDITIONS
}
ATAC_CONDITION_HMM_BAIS = {
    condition: ATAC_CONDITION_HMM_BAMS[condition] + ".bai"
    for condition in ATAC_HMMRATAC_CONDITIONS
}
ATAC_CONDITION_HMM_PEAKS = {
    condition: f"{ATAC_ROOT}/conditions/{condition}/peaks/{condition}.hmmratac.narrowPeak"
    for condition in ATAC_HMMRATAC_CONDITIONS
}
ATAC_CONDITION_HMM_BIGWIGS = {
    condition: f"{ATAC_ROOT}/conditions/{condition}/tracks/{condition}.CPM.bw"
    for condition in ATAC_HMMRATAC_CONDITIONS
}
ATAC_CONDITION_CONSENSUS = {
    condition: f"{ATAC_ROOT}/conditions/{condition}/peaks/{condition}.replicate-supported.bed"
    for condition in ATAC_CONDITION_IDS
}
ATAC_CONDITION_SUPPORT = {
    condition: f"{ATAC_ROOT}/conditions/{condition}/peaks/{condition}.replicate-support.tsv"
    for condition in ATAC_CONDITION_IDS
}
ATAC_CONDITION_STATS = {
    condition: f"{ATAC_ROOT}/conditions/{condition}/peaks/{condition}.replicate-support.json"
    for condition in ATAC_CONDITION_IDS
}

CALLPEAK_NARROW = [
    sample
    for sample in CHIP_TREATMENTS
    if not SAMPLES[sample]["peak_caller"]["broad"]
]
CALLPEAK_BROAD = [
    sample
    for sample in CHIP_TREATMENTS
    if SAMPLES[sample]["peak_caller"]["broad"]
]
CALLPEAK_NARROW_RE = wildcard_regex(CALLPEAK_NARROW)
CALLPEAK_BROAD_RE = wildcard_regex(CALLPEAK_BROAD)
CHIP_PEAKS = {
    sample: (
        f"{RESULT_ROOT}/peaks/{sample}/{sample}_peaks.broadPeak"
        if sample in CALLPEAK_BROAD
        else f"{RESULT_ROOT}/peaks/{sample}/{sample}_peaks.narrowPeak"
    )
    for sample in CHIP_TREATMENTS
}
PEAKS = {
    **CHIP_PEAKS,
    **ATAC_REPLICATE_REFINED,
    **ATAC_REPLICATE_HMM_PEAKS,
}
CALLPEAK_BEDGRAPHS = [
    path
    for sample in CHIP_TREATMENTS
    for path in (
        f"{RESULT_ROOT}/peaks/{sample}/{sample}_treat_pileup.bdg",
        f"{RESULT_ROOT}/peaks/{sample}/{sample}_control_lambda.bdg",
    )
]

RAW_FASTQC = [
    f"{RESULT_ROOT}/qc/fastqc/raw/{unit}.{extension}"
    for unit in RAW_FASTQ_BY_UNIT
    for extension in ("html", "zip")
]
TRIMMED_FASTQC = [
    f"{RESULT_ROOT}/qc/fastqc/trimmed/{unit}.{extension}"
    for unit in TRIMMED_FASTQ_BY_UNIT
    for extension in ("html", "zip")
]
CUTADAPT_JSON = [
    f"{RESULT_ROOT}/qc/cutadapt/{sample}.{lane}.json" for sample, lane in LANES
]
FLAGSTATS = {sample: f"{RESULT_ROOT}/qc/alignment/{sample}.flagstat.txt" for sample in SAMPLE_IDS}
FRIP_JSON = {sample: f"{RESULT_ROOT}/qc/frip/{sample}.json" for sample in TREATMENTS}
FRIP_TSV = {sample: f"{RESULT_ROOT}/qc/frip/{sample}.tsv" for sample in TREATMENTS}
TSS_PLOTS = {sample: f"{RESULT_ROOT}/qc/tss/{sample}.profile.png" for sample in ATAC_SAMPLES}
FRAGMENT_HISTOGRAMS = {
    sample: f"{RESULT_ROOT}/qc/fragments/{sample}.histogram.tsv" for sample in ATAC_SAMPLES
}
FINGERPRINTS = {
    sample: f"{RESULT_ROOT}/qc/chip/{sample}.fingerprint.png"
    for sample in CHIP_CONTROLLED_TREATMENTS
}
CROSSCORRELATION = {
    sample: f"{RESULT_ROOT}/qc/chip/{sample}.cross_correlation.txt"
    for sample in CHIP_TREATMENTS
}
METRICS_TSV = f"{RESULT_ROOT}/qc/metrics.tsv"
METRICS_JSON = f"{RESULT_ROOT}/qc/metrics.json"
MULTIQC_REPORT = f"{RESULT_ROOT}/qc/multiqc/multiqc_report.html"
RESOLVED_CONFIG = f"{RESULT_ROOT}/provenance/resolved_config.json"
REFERENCE_TARGETS = BT2_INDEX + [
    FASTA_INDEX,
    str(REFERENCE["chrom_sizes"]),
    str(REFERENCE["blacklist_bed"]),
    str(REFERENCE["tss_bed"]),
    str(REFERENCE["autosomes_file"]),
]

FINAL_TARGETS = (
    REFERENCE_TARGETS
    + list(FINAL_BAMS.values())
    + list(FINAL_BAIS.values())
    + list(CHIP_BIGWIGS.values())
    + list(ATAC_SHIFTED_BIGWIGS.values())
    + list(PEAKS.values())
    + CALLPEAK_BEDGRAPHS
    + list(ATAC_CONDITION_CANDIDATES.values())
    + list(ATAC_CONDITION_REFINED.values())
    + list(ATAC_CONDITION_EXCLUDED.values())
    + list(ATAC_CONDITION_REFINEMENT_STATS.values())
    + list(ATAC_CONDITION_PILEUP_BW.values())
    + list(ATAC_CONDITION_QPOIS_BW.values())
    + list(ATAC_CONDITION_HMM_PEAKS.values())
    + list(ATAC_CONDITION_HMM_BIGWIGS.values())
    + list(ATAC_CONDITION_CONSENSUS.values())
    + list(ATAC_CONDITION_SUPPORT.values())
    + list(ATAC_CONDITION_STATS.values())
    + list(FRIP_TSV.values())
    + list(TSS_PLOTS.values())
    + list(FRAGMENT_HISTOGRAMS.values())
    + list(FINGERPRINTS.values())
    + list(CROSSCORRELATION.values())
    + [METRICS_TSV, METRICS_JSON, MULTIQC_REPORT, RESOLVED_CONFIG]
)


include: "rules/common.smk"


rule all:
    input:
        FINAL_TARGETS


include: "rules/reference.smk"
include: "rules/read_processing.smk"
include: "rules/alignment.smk"
include: "rules/peaks.smk"
include: "rules/atac_peaks.smk"
include: "rules/atac_consensus.smk"
include: "rules/qc.smk"
